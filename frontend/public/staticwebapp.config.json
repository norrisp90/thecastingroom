{
  "routes": [
    { "route": "/worlds/new", "rewrite": "/worlds/new.html" },
    { "route": "/worlds/*", "rewrite": "/worlds/_.html" },
    { "route": "/admin/*", "rewrite": "/admin/_.html" }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/_next/*", "/images/*", "/*.ico", "/*.svg", "/*.png", "/*.jpg"]
  }
}
